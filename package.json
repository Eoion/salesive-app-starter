{
    "name": "salesive-notes-app",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "description": "Sample Salesive app — a notes manager that syncs with a store's Salesive notes. React + Tailwind frontend and a Node/Express backend on a single port, with OAuth install, a per-store session, and socket.io for live events.",
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "dev": "node server/index.js",
        "build": "vite build",
        "start": "cross-env NODE_ENV=production node server/index.js",
        "preview": "npm run build && npm start"
    },
    "dependencies": {
        "@tiptap/extension-link": "^2.27.2",
        "@tiptap/extension-placeholder": "^2.27.2",
        "@tiptap/pm": "^2.27.2",
        "@tiptap/react": "^2.27.2",
        "@tiptap/starter-kit": "^2.27.2",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "marked": "^18.0.5",
        "mongodb": "^6.21.0",
        "morgan": "^1.11.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^6.30.4",
        "socket.io": "^4.7.5",
        "socket.io-client": "^4.7.5"
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^4.3.1",
        "autoprefixer": "^10.4.19",
        "cross-env": "^10.1.0",
        "postcss": "^8.4.39",
        "tailwindcss": "^3.4.6",
        "vite": "^5.3.3"
    }
}
