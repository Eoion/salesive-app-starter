# The whole app (React UI, API, OAuth, webhooks, socket.io) runs on this ONE port.
PORT=3000

# Public base URL where this app is reachable. Used to build the OAuth redirect_uri
# (APP_BASE_URL + /oauth/callback) — it must EXACTLY match a redirect URI registered
# on your app. For local dev, expose this port with a tunnel (outray, ngrok,
# cloudflared, …) and set this to the public https URL it prints.
APP_BASE_URL=http://localhost:3000

# Optional: a stable outray subdomain (or custom domain) so the tunnel URL doesn't
# change between runs — register it once on your app. Requires `outray login`.
# OUTRAY_SUBDOMAIN=my-salesive-app
# OUTRAY_DOMAIN=app.example.com

# App credentials — Salesive dashboard → Apps → Developer → your app.
SALESIVE_CLIENT_ID=app_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SALESIVE_CLIENT_SECRET=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook signing secret shown in the Developer console (whsec_…). Used to verify
# the X-Salesive-Hmac-SHA256 header on incoming webhooks.
SALESIVE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: secret used to sign this app's own session cookie (the thing that
# proves a browser completed the install — see server/session.js). Defaults to
# SALESIVE_CLIENT_SECRET if unset; set a dedicated long random value to rotate it
# independently. Sessions also require HTTPS in production (SameSite=None; Secure).
# SESSION_SECRET=replace-with-a-long-random-string

# Scopes your app requests at install — comma- or space-separated. Request only
# what you need. This notes app reads AND writes notes, so it needs both. Changing
# scopes requires the merchant to re-install (re-consent) before the new
# permissions take effect.
SALESIVE_SCOPES=READ_NOTES,WRITE_NOTES

# Salesive API host (discovery + token + API). Override only for staging/self-hosted.
SALESIVE_API_BASE=https://api.salesive.com

# Storage. Leave unset to use the zero-config in-memory store (great for trying the
# sample, but installs are lost on restart). Set a MongoDB URI to persist installs
# across restarts and share them between processes — the database name is taken from
# the URI path. If it's set but unreachable, the app warns and falls back to in-memory
# so it still runs.
#
# REQUIRED on Vercel — not optional there. Serverless instances share no memory, so the
# in-memory store would write the pending OAuth state on one instance and look for it on
# another: every install would fail with "invalid state". The app refuses to boot on
# Vercel without this rather than degrade into that bug.
# MONGODB_URI=mongodb://localhost:27017/note-app
